{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PDF Compress GUI",
  "version": "0.1.0",
  "identifier": "com.moonh.pdfcompress",
  "build": {
    "beforeDevCommand": "npm run embed:gs && npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run embed:gs && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PDF Compress GUI",
        "width": 980,
        "height": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "msi", "nsis"],
    "resources": ["resources/ghostscript"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Cross-platform PDF compressor based on Ghostscript",
    "longDescription": "A lightweight desktop app that compresses PDFs by calling Ghostscript with selectable quality levels.",
    "macOS": {
      "minimumSystemVersion": "10.13"
    }
  }
}
